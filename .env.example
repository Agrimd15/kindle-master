# Your Kindle email (found in: Amazon → Manage Your Content and Devices → Preferences → Personal Document Settings)
KINDLE_EMAIL=yourname_abc123@kindle.com

# The email address you'll send FROM (must be approved in Amazon's "Approved Personal Document E-mail List")
SENDER_EMAIL=you@gmail.com

# Gmail: use an App Password (myaccount.google.com → Security → App Passwords)
# Outlook/Hotmail: use your regular password or an app password
SENDER_PASSWORD=your_app_password_here

# SMTP settings (defaults work for Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
