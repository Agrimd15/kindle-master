# ── Telegram Bot ────────────────────────────────────────────────────────────
# Get this from @BotFather on Telegram (/newbot)
BOT_TOKEN=your_telegram_bot_token_here

# ── Email (sends the epub to Kindle) ────────────────────────────────────────
# The address this bot sends FROM (your Gmail or any SMTP account)
SENDER_EMAIL=you@gmail.com

# Gmail: create an App Password at myaccount.google.com/apppasswords
# Outlook/iCloud: use an app-specific password from your account settings
SENDER_PASSWORD=your_app_password_here

# SMTP server settings — defaults below work for Gmail, change for other providers
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ── CLI only (not needed for the bot) ───────────────────────────────────────
# If running via command line (main.py), set your personal Kindle email here.
# Bot users set their own Kindle email via /setup — this field is not used by the bot.
# KINDLE_EMAIL=yourname_abc123@kindle.com
